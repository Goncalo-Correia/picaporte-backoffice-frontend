{
  "buildCommand": "cd picaporte-frontend && npm install && npm run build",
  "outputDirectory": "picaporte-frontend/dist/picaporte-frontend/browser",
  "installCommand": "echo 'install handled in buildCommand'",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
